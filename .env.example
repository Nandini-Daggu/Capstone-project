# ============================================================
# Competitive Intelligence Briefing Crew - Environment Config
# Copy this file to .env and fill in your real values.
# ============================================================

# ── LLM Configuration (OpenRouter) ──────────────────────────
# Get your free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=${OPENROUTER_API_KEY}

# ── Single model config variable ────────────────────────────
# This is the primary/default model used by all agents.
# Format: openrouter/<provider>/<model-slug>:<tier>
#
# Valid FREE models (confirmed against OpenRouter /models API):
#   openrouter/google/gemma-4-31b-it:free            ctx=262k  ← recommended
#   openrouter/google/gemma-4-26b-a4b-it:free         ctx=262k
#   openrouter/meta-llama/llama-3.3-70b-instruct:free ctx=131k
#   openrouter/meta-llama/llama-3.2-3b-instruct:free  ctx=131k
#   openrouter/qwen/qwen3-coder:free                  ctx=1M
#   openrouter/nvidia/nemotron-3-ultra-550b-a55b:free  ctx=1M
#   openrouter/nvidia/nemotron-3-super-120b-a12b:free  ctx=1M
#   openrouter/nousresearch/hermes-3-llama-3.1-405b:free ctx=131k
#
# NOTE: Do NOT use the "openrouter/" prefix TWICE.
#   WRONG: openrouter/openrouter/google/gemma-4-31b-it:free
#   RIGHT: openrouter/google/gemma-4-31b-it:free
MODEL_NAME=openrouter/google/gemma-4-31b-it:free

# ── Model cascade (primary → fallback → last-resort) ────────
# The cascade is tried in order when a model returns a 429.
# Choose models from DIFFERENT providers to avoid one outage
# killing the entire cascade:
#   gemma-4-31b-it      → Google AI Studio  (provider: Google)
#   llama-3.3-70b       → Venice / Meta     (provider: Venice)
#   qwen3-coder         → Venice / Qwen     (provider: Venice)
MODEL_PRIMARY=openrouter/google/gemma-4-31b-it:free
MODEL_FALLBACK=openrouter/meta-llama/llama-3.3-70b-instruct:free
MODEL_LAST_RESORT=openrouter/qwen/qwen3-coder:free

# ── Search APIs (optional — web search degrades gracefully) ──
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERPAPI_API_KEY=                         # Optional

# ── Embedding Model (local, no API cost) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu                     # cpu | cuda | mps

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./database/intelligence.db
DATABASE_ECHO=false

# ── Cache ────────────────────────────────────────────────────
CACHE_DIR=./cache
CACHE_TTL_SECONDS=3600
LLM_CACHE_ENABLED=true
SEARCH_CACHE_ENABLED=true
EMBEDDING_CACHE_ENABLED=true

# ── Vector Store ─────────────────────────────────────────────
VECTORSTORE_DIR=./knowledge_base/vectorstore
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5

# ── Run Limits (Governance) ──────────────────────────────────
MAX_SOURCES=5                 # sources per search (lower = faster)
MAX_STEPS=10                  # max agent steps per run (lower = faster)
MAX_RUNTIME_SECONDS=300       # 5 min timeout
MAX_COST_USD=0.02

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
AUDIT_LOG_FILE=./logs/audit.jsonl
TRACE_LOG_FILE=./logs/trace.jsonl

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_SECRET_KEY=change-me-in-production-use-strong-random-string

# ── Streamlit ────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Export ───────────────────────────────────────────────────
OUTPUT_DIR=./outputs
REPORT_TEMPLATE=mckinsey

# ── Evaluation ───────────────────────────────────────────────
EVALUATION_ENABLED=true
RAGAS_ENABLED=true
DEEPEVAL_ENABLED=true

# ── Human Review ─────────────────────────────────────────────
HUMAN_REVIEW_ENABLED=true
AUTO_APPROVE_THRESHOLD=0.85        # Auto-approve if confidence >= this

# ── Observability ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317

# ── Security ─────────────────────────────────────────────────
PROMPT_INJECTION_GUARD=true
MISINFORMATION_GUARD=true
UNCITED_CLAIM_GUARD=true
