# ============================================================
# Competitive Intelligence Briefing Crew - .gitignore
# ============================================================

# ── Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Virtual Environments ─────────────────────────────────────
venv312/
.venv/
venv/
env/
ENV/
.python-version

# ── Python bytecode ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.whl

# ── Database (all SQLite files including WAL/SHM journals) ───
database/*.db
database/*.db-shm
database/*.db-wal
database/*.sqlite
database/*.sqlite-shm
database/*.sqlite-wal
*.db
*.db-shm
*.db-wal
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.jsonl

# ── Generated outputs ────────────────────────────────────────
outputs/
*.pdf
*.pptx

# ── Cache ────────────────────────────────────────────────────
cache/
.cache/
*.diskcache/

# ── Vector Store ─────────────────────────────────────────────
knowledge_base/vectorstore/
*.faiss
*.pkl

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover
coverage.xml
nosetests.xml
test-results/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ───────────────────────────────────────────────────
.docker/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
*.tmp
*.bak
*.orig

# ── Secrets / Credentials ────────────────────────────────────
*.pem
*.key
credentials.json
service-account.json

# ── Node (for promptfoo) ─────────────────────────────────────
node_modules/
package-lock.json
